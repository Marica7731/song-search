{
  "name": "song-search",
  "version": "1.0.0",
  "private": true,
  "description": "Song search site with optional server-side API mode",
  "scripts": {
    "start": "node server.js",
    "check:library": "node scripts/check-song-library.js",
    "check:live": "node scripts/check-live-song-total.js",
